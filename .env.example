# ============================================================
# BetPredict Pro — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://betpredict:your_password@localhost:5432/betpredict

# Optional: maximum DB connections per process (default: 10)
DB_POOL_MAX=10

# ── API Server ────────────────────────────────────────────────
# Port for the API/app server (default: 8080)
PORT=8080

# Node environment: "development" | "production"
NODE_ENV=production

# ── External APIs ─────────────────────────────────────────────
# football-data.org API key (free tier: 10 req/min)
# Sign up at https://www.football-data.org/
FOOTBALL_DATA_API_KEY=your_key_here

# ── Frontend ──────────────────────────────────────────────────
# In production the API server serves the built frontend.
# Set STATIC_DIR to the path of the built frontend (artifacts/betpredict/dist/public)
STATIC_DIR=/app/public

# CORS allowed origin(s) — use * to allow all (default: *)
# In production set this to your domain, e.g. https://betpredict.example.com
CORS_ORIGIN=*

# ── Docker Compose only ───────────────────────────────────────
# Password for the local postgres container
POSTGRES_PASSWORD=betpredict_secret

# Host port the app is exposed on (default: 8080)
APP_PORT=8080
